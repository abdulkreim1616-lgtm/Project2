<?xml version="1.0" ?>
<sdf version="1.10">
  <model name="helipad_1">
    <static>true</static>
    <link name="link">

      <visual name="visual">
        <geometry>
          <mesh>
            <uri>model://helipad_1/meshes/helipad.glb</uri>
            <scale>0.5 0.5 0.5</scale>
          </mesh>
        </geometry>
      </visual>

      <collision name="collision">
        <geometry>
          <box><size>1 0.1 1</size></box>
        </geometry>
      </collision>

    </link>
  </model>
</sdf>
